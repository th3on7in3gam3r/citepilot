{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "getcitepilot.com" }],
      "destination": "https://www.getcitepilot.com/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/weekly-rescan",
      "schedule": "0 12 * * 1"
    },
    {
      "path": "/api/cron/weekly-ops-report",
      "schedule": "0 15 * * 1"
    },
    {
      "path": "/api/cron/email-sequences",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/account-deletion",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/scheduled-scans",
      "schedule": "0 11 * * *"
    }
  ]
}
