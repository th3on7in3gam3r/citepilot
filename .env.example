# CitePilot — copy to .env.local (Next.js does NOT load this file)

# Live LLM citation checks during audits + article generation
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional — live Perplexity citation checks (ChatGPT + Google use OpenAI + Serper above)
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar

# Intentionally public — UI label only ("live" vs technical audit copy). Not a secret.
NEXT_PUBLIC_AUDIT_MODE=

# Higher Stack Exchange API quota (https://stackapps.com)
STACKEXCHANGE_KEY=

# Web search for Discussions + Backlink discovery (Serper tried first, then Tavily)
SERPER_API_KEY=
TAVILY_API_KEY=

# Optional — third-party domain authority (https://www.domcop.com/openpagerank)
OPEN_PAGERANK_API_KEY=

# Neon Postgres — use either name. Omit both locally to use SQLite (.data/citepilot.db)
DATABASE_URL=
NEON_URL=

# Neon Auth — enable in Neon Console → Branch → Auth → Configuration
NEON_AUTH_BASE_URL=
NEON_AUTH_COOKIE_SECRET=

# Workspace CMS credentials are encrypted before saving to the database.
# Production should set a stable 32+ character secret:
#   openssl rand -base64 32
CMS_ENCRYPTION_KEY=

# Internal admin console — protects /admin when set (use /admin/login)
ADMIN_SECRET=

# Webflow CMS — use a SITE token from CitePilot → Site settings → Integrations → API access
# Required scope: cms:write. Recommended: cms:read, sites:publish
WEBFLOW_API_KEY=
WEBFLOW_SITE_ID=
WEBFLOW_COLLECTION_ID=
# Optional field slug overrides (defaults match Blog Posts: name, slug, body-post)
# WEBFLOW_FIELD_NAME=name
# WEBFLOW_FIELD_SLUG=slug
# WEBFLOW_FIELD_BODY=body-post
# WEBFLOW_BLOG_PATH=/blog
# WEBFLOW_PREVIEW_URL=https://citepilot.design.webflow.com
# WEBFLOW_AUTO_PUBLISH_SITE=true

# Stripe — Pilot subscription ($79/mo)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Price ID from Stripe Dashboard → Products → Pilot → Pricing
STRIPE_PILOT_PRICE_ID=
# Fleet subscription ($249/mo)
STRIPE_FLEET_PRICE_ID=
# Optional — defaults to http://localhost:3000 or VERCEL_URL
# NEXT_PUBLIC_APP_URL=https://getcitepilot.com

# Resend — weekly digest + audit/score-drop alerts
RESEND_API_KEY=
EMAIL_FROM=CitePilot <alerts@getcitepilot.com>
# Protects GET /api/cron/* (required on Vercel production; Cron sends Authorization: Bearer …)
CRON_SECRET=

# Preview/staging only — never set on production (unlocks paid features without Stripe)
# ALLOW_BILLING_BYPASS=1

# Google Search Console OAuth (Analytics → Google tab)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Workspace CMS connections (WordPress / Ghost / Shopify / Framer) do not use
# env vars for provider credentials. Connect them from Dashboard → Content and
# they will be stored encrypted in the database using CMS_ENCRYPTION_KEY.

# Sentry (optional) — server + client error reporting. Server-only; @sentry/nextjs injects
# the DSN into the browser bundle at build time. Do not duplicate as NEXT_PUBLIC_*.
SENTRY_DSN=
# SENTRY_ORG=  SENTRY_PROJECT=  (for source maps upload in CI)

# Product analytics (optional) — funnel: audit → signup → Pilot → CMS → re-audit
# NEXT_PUBLIC_* below are intentionally browser-visible (same model as Stripe publishable keys).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Browser PostHog SDK — project key (phc_…) from PostHog → Project settings
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Server-side capture for API routes only — set the same phc_ key here; never read from NEXT_PUBLIC_* on server
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Weekly ops summary email (Mondays 15:00 UTC cron) — defaults to EMAIL_FROM / support
ADMIN_OPS_EMAIL=hello@getcitepilot.com

# Not wired yet — reserved for future features
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
