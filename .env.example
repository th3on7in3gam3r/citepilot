# CitePilot — copy to .env.local (Next.js does NOT load this file)

# Live LLM citation checks during audits + article generation
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Set to "live" when OPENAI_API_KEY is configured
NEXT_PUBLIC_AUDIT_MODE=

# Higher Stack Exchange API quota (https://stackapps.com)
STACKEXCHANGE_KEY=

# Web search for Discussions (Serper tried first, then Tavily)
SERPER_API_KEY=
TAVILY_API_KEY=

# Neon Postgres — use either name. Omit both locally to use SQLite (.data/citepilot.db)
DATABASE_URL=
NEON_URL=

# Neon Auth — enable in Neon Console → Branch → Auth → Configuration
NEON_AUTH_BASE_URL=
NEON_AUTH_COOKIE_SECRET=

# Internal admin console — protects /admin when set (use /admin/login)
ADMIN_SECRET=

# Webflow CMS — use a SITE token from CitePilot → Site settings → Integrations → API access
# Required scope: cms:write. Recommended: cms:read, sites:publish
WEBFLOW_API_KEY=
WEBFLOW_SITE_ID=
WEBFLOW_COLLECTION_ID=
# Optional field slug overrides (defaults match Blog Posts: name, slug, body-post)
# WEBFLOW_FIELD_NAME=name
# WEBFLOW_FIELD_SLUG=slug
# WEBFLOW_FIELD_BODY=body-post
# WEBFLOW_BLOG_PATH=/blog
# WEBFLOW_PREVIEW_URL=https://citepilot.design.webflow.com
# WEBFLOW_AUTO_PUBLISH_SITE=true

# Stripe — Pilot subscription ($79/mo)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Price ID from Stripe Dashboard → Products → Pilot → Pricing
STRIPE_PILOT_PRICE_ID=
# Optional — defaults to http://localhost:3000 or VERCEL_URL
# NEXT_PUBLIC_APP_URL=https://getcitepilot.com

# Not wired yet — reserved for future features
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
