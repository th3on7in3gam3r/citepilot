# CitePilot — copy to .env.local (Next.js does NOT load this file)

# Live LLM citation checks during audits + article generation
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional — live Perplexity citation checks (ChatGPT + Google use OpenAI + Serper above)
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar

# Intentionally public — UI label only ("live" vs technical audit copy). Not a secret.
NEXT_PUBLIC_AUDIT_MODE=

# Higher Stack Exchange API quota (https://stackapps.com)
STACKEXCHANGE_KEY=

# Web search for Discussions, Backlinks, and Google AI Overviews probes
# Serper is tried first when both are set; SerpAPI is the fallback.
SERPER_API_KEY=
SERPAPI_API_KEY=
TAVILY_API_KEY=

# Optional — third-party domain authority (https://www.domcop.com/openpagerank)
OPEN_PAGERANK_API_KEY=

# Neon Postgres — use either name. Omit both locally to use SQLite (.data/citepilot.db)
# Runtime: prefer DATABASE_URL_POOLED (PgBouncer) for lower serverless latency.
# Migrations / DDL: use DATABASE_URL_DIRECT (non-pooled endpoint).
DATABASE_URL=
DATABASE_URL_POOLED=
DATABASE_URL_DIRECT=
NEON_URL=

# Neon Auth — enable in Neon Console → Branch → Auth → Configuration
NEON_AUTH_BASE_URL=
NEON_AUTH_COOKIE_SECRET=

# Workspace CMS credentials are encrypted before saving to the database.
# Production should set a stable 32+ character secret:
#   openssl rand -base64 32
CMS_ENCRYPTION_KEY=

# Protects GET /api/health detailed diagnostics (send header X-Health-Secret: …)
HEALTH_SECRET=

# Internal admin console — comma-separated Neon Auth emails allowed at /admin
ADMIN_EMAILS=you@getcitepilot.com
# Legacy shared-secret admin login (deprecated — use ADMIN_EMAILS)
# ADMIN_SECRET=

# Webflow CMS — use a SITE token from CitePilot → Site settings → Integrations → API access
# Required scope: cms:write. Recommended: cms:read, sites:publish
WEBFLOW_API_KEY=
WEBFLOW_SITE_ID=
WEBFLOW_COLLECTION_ID=
# Optional field slug overrides (defaults match Blog Posts: name, slug, body-post)
# WEBFLOW_FIELD_NAME=name
# WEBFLOW_FIELD_SLUG=slug
# WEBFLOW_FIELD_BODY=body-post
# WEBFLOW_BLOG_PATH=/blog
# WEBFLOW_PREVIEW_URL=https://citepilot.design.webflow.com
# WEBFLOW_AUTO_PUBLISH_SITE=true

# Stripe — Pilot subscription ($79/mo)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Price ID from Stripe Dashboard → Products → Pilot → Pricing
STRIPE_PILOT_PRICE_ID=
# TODO: create annual prices in Stripe ($756/yr Pilot, $2388/yr Fleet)
STRIPE_PILOT_ANNUAL_PRICE_ID=
# Fleet subscription ($249/mo)
STRIPE_FLEET_PRICE_ID=
STRIPE_FLEET_ANNUAL_PRICE_ID=
# Optional — defaults to http://localhost:3000 or VERCEL_URL
# NEXT_PUBLIC_APP_URL=https://getcitepilot.com
# Sister product — AI CMO workspace (growth stack Phase 1)
# NEXT_PUBLIC_AI_CMO_APP_URL=http://localhost:3000/app

# Slack OAuth — citation digests & change alerts (Pilot+)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Fleet white-label — CNAME target for custom report domains (e.g. reports.youragency.com)
# REPORTS_CNAME_TARGET=reports.getcitepilot.com

# Resend — weekly digest + audit/score-drop alerts + blog newsletter
RESEND_API_KEY=
EMAIL_FROM=CitePilot <alerts@getcitepilot.com>
# Do NOT use Resend doc placeholders like alerts@yourverifieddomain.com — verify your domain first.
# Local dev without a verified domain: set to 1 to send via onboarding@resend.dev
# (Resend only delivers to your account email until the domain is verified)
# RESEND_USE_TEST_FROM=1
# Optional — Resend segment for blog "Weekly GEO brief" subscribers
RESEND_NEWSLETTER_SEGMENT_ID=
# Protects GET /api/cron/* (required on Vercel production; Cron sends Authorization: Bearer …)
CRON_SECRET=

# Preview/staging only — never set on production (unlocks paid features without Stripe)
# ALLOW_BILLING_BYPASS=1

# Google Search Console OAuth (Analytics → Google tab)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Workspace CMS connections (WordPress / Ghost / Shopify / Framer) do not use
# env vars for provider credentials. Connect them from Dashboard → Content and
# they will be stored encrypted in the database using CMS_ENCRYPTION_KEY.

# Sentry (optional) — server + client error reporting. Server-only; @sentry/nextjs injects
# the DSN into the browser bundle at build time. Do not duplicate as NEXT_PUBLIC_*.
SENTRY_DSN=
# SENTRY_ORG=  SENTRY_PROJECT=  (for source maps upload in CI)
# SENTRY_AUTH_TOKEN=  (weekly ops digest — Sentry error rate + top issues)

# Product analytics (optional) — funnel: audit → signup → Pilot → CMS → re-audit
# NEXT_PUBLIC_* below are intentionally browser-visible (same model as Stripe publishable keys).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Browser PostHog SDK — project key (phc_…) from PostHog → Project settings
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Server-side capture for API routes only — set the same phc_ key here; never read from NEXT_PUBLIC_* on server
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Chrome Web Store listing URL (marketing page CTA) — set after extension is approved
NEXT_PUBLIC_CHROME_WEB_STORE_URL=

# Weekly ops summary email (Mondays 15:00 UTC cron)
OPS_REPORT_EMAIL=ops@getcitepilot.com
# Deprecated alias — use OPS_REPORT_EMAIL instead
# ADMIN_OPS_EMAIL=

# Browser-based citation scanning (Grok, Google AI Overviews UI) via Claude Managed Agents + Browser Use Cloud
# Run once: ant beta:agents create …  → save agent ID
# Run once: ant beta:environments create …  → save environment ID
ANTHROPIC_API_KEY=
# Optional — Claude model for Pilot+ Site Optimizer (/dashboard/optimizer)
# ANTHROPIC_OPTIMIZER_MODEL=claude-sonnet-4-20250514
ANTHROPIC_AGENT_ID=
BROWSER_USE_ENVIRONMENT_ID=

# Product Hunt launch (set LAUNCH_MODE=true for 24–48h on launch day)
# Step-by-step setup: launch/ENV_SETUP.md
# LAUNCH_MODE=true
# PH_LAUNCH_DATE=2026-06-03
# PH_PRODUCT_HUNT_URL=https://www.producthunt.com/products/citepilot
# NEXT_PUBLIC_PH_PRODUCT_HUNT_URL=
# NEXT_PUBLIC_PH_LAUNCH_DATE=
# NEXT_PUBLIC_FOUNDER_NAME=
# FOUNDER_NAME=
# FOUNDER_EMAIL=hello@getcitepilot.com
# NEXT_PUBLIC_FOUNDER_TWITTER=https://twitter.com/citepilot
# NEXT_PUBLIC_FOUNDER_LINKEDIN=https://linkedin.com/company/citepilot
# NEXT_PUBLIC_FOUNDER_PHOTO=/press/founder.jpg
# Press inbox — set up forwarding in Resend (see launch/ENV_SETUP.md)
# PRESS_EMAIL=press@getcitepilot.com

# Studio Ops — lifecycle event fan-out to central ops (optional; no-op when unset)
# STUDIO_OPS_URL=https://your-studio-ops-host/api/events
# STUDIO_OPS_SECRET=
# Alias accepted: STUDIO_OPS_WEBHOOK_SECRET

# Studio Billing — inbound bundle webhooks from partner checkout (optional)
# STUDIO_BILLING_FANOUT_SECRET=
